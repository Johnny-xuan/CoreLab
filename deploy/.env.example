# CoreLab — environment configuration template
#
# Copy this file to `.env` and fill in real values before running
# `docker compose up -d`. `.env` is git-ignored (root .gitignore).
#
# Generate strong random secrets with:
#     openssl rand -base64 32   # MYSQL passwords
#     openssl rand -base64 48   # JWT_SECRET (≥ 32 bytes)
#
# ─── REQUIRED (do NOT ship defaults to prod) ──────────────────────────

MYSQL_ROOT_PASSWORD=__GENERATE_ME_OPENSSL_RAND_BASE64_32__
# DB user with full grants on corelab.* — used by alembic for migrations only.
MYSQL_USER_PASSWORD=__GENERATE_ME_OPENSSL_RAND_BASE64_32__
# DB user with SELECT/INSERT/UPDATE only (no DELETE anywhere) — runtime FastAPI.
# Created by deploy/mysql-init/01-create-app-user.sh on first mysql startup.
MYSQL_APP_USER_PASSWORD=__GENERATE_ME_OPENSSL_RAND_BASE64_32__
JWT_SECRET=__GENERATE_ME_OPENSSL_RAND_BASE64_48__

# ─── OPTIONAL (sensible defaults shown) ────────────────────────────────

# Host port the MySQL container exposes (dev convenience: pytest /
# Workbench can connect directly to localhost:3307 without going through
# docker network). In prod, drop the `ports:` section in docker-compose.yml.
MYSQL_HOST_PORT=3307

# Host-side data directory for MySQL, backend logs, and Caddy state.
# For smoke tests, set this to a temporary absolute path so the test stack
# does not touch deploy/data.
CORELAB_DATA_DIR=./data

# Caddy HTTP port. Set to 8080 if :80 is taken on host.
HTTP_PORT=80

# Public URL where the user reaches CoreLab.
#
# This URL is baked into the agent install snippet shown on the
# Enrollment tokens page. When an agent is installed on a *remote* GPU
# host, the script `curl`s the backend at this URL and the agent
# connects back over WSS derived from it (http → ws / https → wss).
#
# If left unset, docker-compose derives http://localhost:${HTTP_PORT:-80}.
# So:
#   * Local single-host dev:  leave unset, or set http://localhost:<HTTP_PORT>
#   * Remote / multi-host:    http://<lan-ip>  or
#                             https://corelab.your-lab.example.com
#
# `http://localhost` will silently break enrollment when the agent
# runs on a different machine from the backend. Override here, OR set
# CORELAB_BACKEND_URL=<real-url> in the env you pass to install-agent.sh.
# BACKEND_PUBLIC_URL=http://localhost

# CORS origins (comma-separated). Keep Vite dev server here for local
# frontend development; empty is fine when Caddy/backend serves one origin.
CORS_ORIGINS=http://localhost:5173

# Logging verbosity: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Backend background jobs. Leave enabled for normal deployments; set
# SCHEDULER_ENABLED=false only for one-off debugging where the reservation
# tick and URL probe scheduler must not run.
SCHEDULER_ENABLED=true
SCHEDULER_TICK_SECONDS=30

# Backend image tag (built by docker compose)
IMAGE_TAG=local-dev
